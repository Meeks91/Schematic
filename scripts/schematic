#!/usr/bin/env python3

import argparse
import hashlib
import json
import re
import subprocess
import sys
import textwrap
import time
from datetime import datetime, timezone
from pathlib import Path

# ── constants ──────────────────────────────────────────────────────────────────

SCHEMATICS_BASE = "docs/schematics"
STANDARDS_MANIFEST_RELPATH_CANONICAL = ".schematic/standards.json"
STANDARDS_MANIFEST_RELPATH = ".claude/standards.json"
ARCHIVE_SUBDIR = "_archive"
STATE_FILENAME = ".schematic-state.json"

TASK_STATUS_PENDING = "pending"
TASK_STATUS_IN_PROGRESS = "in_progress"
TASK_STATUS_REVIEW = "review"
TASK_STATUS_COMPLETE = "complete"
VALID_TASK_STATUSES = {TASK_STATUS_PENDING, TASK_STATUS_IN_PROGRESS, TASK_STATUS_REVIEW, TASK_STATUS_COMPLETE}

REVIEW_MODEL_DEFAULT = "sonnet"
REVIEW_MODEL_KEY = "reviewModel"
SCHEMATIC_CONFIG_KEY = "schematic"
REVIEW_VERDICT_CLEAN = "clean"
REVIEW_VERDICT_FINDINGS = "findings"
REVIEW_VERDICTS = {REVIEW_VERDICT_CLEAN, REVIEW_VERDICT_FINDINGS}

MAX_FILES_PER_REVIEW_BATCH = 5  # token bound: a sweep subagent reads at most this many files, nothing else
RUN_MODE_MANUAL = "manual"  # per-task sketch gate (default)
RUN_MODE_AUTO = "auto"      # long-running driver loop + batch-until-pristine sweep
VALID_RUN_MODES = {RUN_MODE_MANUAL, RUN_MODE_AUTO}
SWEEP_STATUS_PRISTINE = "pristine"
REVIEW_SLOT_KEY = "review"

FINAL_PHASE = 9
PLANNING_FINAL_PHASE = 7  # phases 1-7 plan; 8 implements; 9 compresses
VALID_PHASES = set(range(1, FINAL_PHASE + 1))
PHASES_REQUIRING_AUDIT = {1, 2, 4, 6, 7}
PHASE_ARTIFACT_CHECKS: dict[int, list[tuple[str, str]]] = {
    3: [("objective.md", "## Directory Structure")],
    5: [("components/_overview.md", "## Injection DAG"),
        ("components/_overview.md", "## App Integration")],
    6: [("sequence.mmd", ""),
        ("components/_overview.md", "## Sequence Diagram")],
    8: [("implementation_report.md", "")],
}
PHASE_MERMAID_CHECKS: dict[int, list[str]] = {
    5: ["dag.mmd"],
    6: ["sequence.mmd"],
}
PHASE_STATUS_LOCKED = "locked"
PHASE_AUDIT_CLEAN = "clean"

STANDARDS_SLOTS = ("architecture", "types", "common", "styling", "testing", "review", "exemplars")

TASK_HEADER_RE = re.compile(r"^## ([a-z]\.\d+) \| (\w+) \| (.+)$")
FEATURE_AC_RE = re.compile(r"(\d+\.[A-Z])\b")
BLOCKED_BY_TAG_RE = re.compile(r"\b([a-z]\.\d+)\b")

LEGAL_TASK_TRANSITIONS: dict[str, set[str]] = {
    TASK_STATUS_PENDING: {TASK_STATUS_IN_PROGRESS},
    TASK_STATUS_IN_PROGRESS: {TASK_STATUS_REVIEW, TASK_STATUS_COMPLETE},
    TASK_STATUS_REVIEW: {TASK_STATUS_COMPLETE, TASK_STATUS_IN_PROGRESS},
    TASK_STATUS_COMPLETE: set(),
}

SEQUENCE_OPENERS = {"loop", "alt", "opt", "par", "critical", "break", "rect"}
VALID_NOTE_PREFIXES = ("Note over ", "Note left of ", "Note right of ")
FLOWCHART_SKIP_KEYWORDS = {"subgraph", "style", "classDef", "linkStyle", "end", "direction", "click"}
MERMAID_UNCHECKED_TYPES_RE = re.compile(
    r"^(classDiagram|erDiagram|gantt|pie|gitGraph|mindmap|timeline|xychart|block)"
)

# ── file discovery ─────────────────────────────────────────────────────────────

def find_project_root() -> Path:
    current = Path.cwd()
    while current != current.parent:
        if (current / SCHEMATICS_BASE).exists() or (current / ".git").exists():
            return current
        current = current.parent
    return Path.cwd()


def resolve_schematic_dir(name: str) -> Path:
    path = find_project_root() / SCHEMATICS_BASE / name
    if not path.exists():
        _exit_error(f"schematic '{name}' not found at {path}")
    return path


def list_schematic_dirs() -> list[Path]:
    base = find_project_root() / SCHEMATICS_BASE
    if not base.exists():
        return []
    return sorted(
        p for p in base.iterdir()
        if p.is_dir() and p.name != ARCHIVE_SUBDIR
    )

# ── state I/O ──────────────────────────────────────────────────────────────────

def load_state(schematic_dir: Path) -> dict:
    state_path = schematic_dir / STATE_FILENAME
    if not state_path.exists():
        return {"phases": {}, "tasks": {}, "overrides": [], "run": None, "sweeps": []}
    loaded_state = json.loads(state_path.read_text())
    loaded_state.setdefault("run", None)
    loaded_state.setdefault("sweeps", [])
    return loaded_state


def save_state(schematic_dir: Path, state: dict) -> None:
    (schematic_dir / STATE_FILENAME).write_text(json.dumps(state, indent=2) + "\n")


def record_override(state: dict, context: str, reason: str) -> None:
    state["overrides"].append({
        "context": context,
        "reason": reason,
        "at": datetime.now(tz=timezone.utc).isoformat(),
    })

# ── diff collection ──────────────────────────────────────────────────────────────

def _run_git(git_args: list[str], project_root: Path) -> list[str]:
    """Run a git command in project_root; return non-empty stdout lines."""
    completed = subprocess.run(
        ["git", *git_args],
        cwd=project_root,
        capture_output=True,
        text=True,
    )
    if completed.returncode != 0:
        _exit_error(f"git {' '.join(git_args)} failed: {completed.stderr.strip()}")
    return [line.strip() for line in completed.stdout.splitlines() if line.strip()]


def _run_git_raw(git_args: list[str], project_root: Path) -> str:
    """Run a git command in project_root; return raw stdout."""
    completed = subprocess.run(
        ["git", *git_args],
        cwd=project_root,
        capture_output=True,
        text=True,
    )
    if completed.returncode != 0:
        _exit_error(f"git {' '.join(git_args)} failed: {completed.stderr.strip()}")
    return completed.stdout


def _cumulative_diff_files(base_ref: str, project_root: Path) -> list[str]:
    """Feature files changed since base_ref — tracked diffs plus new untracked, minus schematic planning artifacts."""
    tracked_changed = _run_git(["diff", "--name-only", base_ref], project_root)
    untracked_new = _run_git(["ls-files", "--others", "--exclude-standard"], project_root)
    all_changed = set(tracked_changed) | set(untracked_new)
    return sorted(path for path in all_changed if not path.startswith(SCHEMATICS_BASE + "/"))


def _file_diff(path: str, base_ref: str, project_root: Path) -> str:
    """Diff hunks for one file since base_ref; untracked files render as fully-added hunks."""
    tracked = _run_git_raw(["diff", base_ref, "--", path], project_root)
    if tracked:
        return tracked
    # `git diff base_ref` is empty for untracked files — synthesize the all-added diff.
    completed = subprocess.run(
        ["git", "diff", "--no-index", "--", "/dev/null", path],
        cwd=project_root,
        capture_output=True,
        text=True,
    )
    return completed.stdout


def _diff_hash(diff_content: str) -> str:
    return hashlib.sha256(diff_content.encode("utf-8")).hexdigest()


def _clean_reviewed_file_hashes(state: dict) -> dict[str, set[str]]:
    """Per file: the diff hashes that already passed a clean batch review in any prior sweep."""
    path_to_hashes: dict[str, set[str]] = {}
    for sweep in state.get("sweeps", []):
        for batch in sweep.get("batches", []):
            if batch.get("verdict") != REVIEW_VERDICT_CLEAN:
                continue
            for path, diff_hash in batch.get("file_hashes", {}).items():
                path_to_hashes.setdefault(path, set()).add(diff_hash)
    return path_to_hashes


def _shard_diff_into_batches(changed_files: list[str], max_files_per_batch: int) -> list[list[str]]:
    """Split changed files into ordered batches of at most max_files_per_batch each."""
    return [
        changed_files[start : start + max_files_per_batch]
        for start in range(0, len(changed_files), max_files_per_batch)
    ]


def _load_standards_manifest(project_root: Path) -> dict:
    """Canonical .schematic/ manifest, else .claude/ (back-compat) — repo first, then user-global; else empty."""
    manifest_paths = (
        project_root / STANDARDS_MANIFEST_RELPATH_CANONICAL,
        project_root / STANDARDS_MANIFEST_RELPATH,
        Path.home() / STANDARDS_MANIFEST_RELPATH_CANONICAL,
        Path.home() / STANDARDS_MANIFEST_RELPATH,
    )
    for manifest_path in manifest_paths:
        if manifest_path.exists():
            return json.loads(manifest_path.read_text())
    return {}


def _resolve_review_model(project_root: Path) -> str:
    """Review model from manifest's schematic.reviewModel, else default."""
    manifest = _load_standards_manifest(project_root)
    schematic_config = manifest.get(SCHEMATIC_CONFIG_KEY, {})
    return schematic_config.get(REVIEW_MODEL_KEY, REVIEW_MODEL_DEFAULT)


def _resolve_source_path(source: str, project_root: Path) -> Path | None:
    """Resolve a manifest source ('skill:<name>' or 'file:<path>') to a readable path."""
    if source.startswith("skill:"):
        return _resolve_skill_path(source)
    if source.startswith("file:"):
        raw_path = Path(source[len("file:"):]).expanduser()
        candidate = raw_path if raw_path.is_absolute() else project_root / raw_path
        return candidate if candidate.exists() else None
    return None


def _resolved_slot_paths(project_root: Path) -> dict[str, Path]:
    """Every mapped manifest slot resolved to its module path (styling flattened per language)."""
    manifest = _load_standards_manifest(project_root)
    slot_to_path: dict[str, Path] = {}
    for slot in STANDARDS_SLOTS:
        source = manifest.get(slot)
        if slot == "styling" and isinstance(source, dict):
            for lang, lang_source in source.items():
                path = _resolve_source_path(lang_source, project_root)
                if path:
                    slot_to_path[f"styling.{lang}"] = path
        elif isinstance(source, str):
            path = _resolve_source_path(source, project_root)
            if path:
                slot_to_path[slot] = path
    return slot_to_path


# ── standards content resolution (for inline review prompts) ─────────────────

_LANGUAGE_EXTENSIONS: dict[str, str] = {
    ".py": "python",
    ".kt": "kotlin",
    ".kts": "kotlin",
    ".ts": "typescript",
    ".tsx": "typescript",
}


def _resolve_skill_path(source: str) -> Path | None:
    """Resolve a 'skill:<name>' source to its SKILL.md path (repo-local then user-global)."""
    if not source.startswith("skill:"):
        return None
    skill_name = source[len("skill:"):]
    project_root = find_project_root()
    for base in (project_root / ".claude" / "skills", Path.home() / ".claude" / "skills"):
        candidate = base / skill_name / "SKILL.md"
        if candidate.exists():
            return candidate
    return None


def _resolve_standards_content_for_batch(batch_files: list[str], project_root: Path) -> str:
    """Read and concatenate the styling + testing standards modules relevant to the batch's languages."""
    manifest = _load_standards_manifest(project_root)

    # Determine which languages appear in this batch.
    languages_in_batch: set[str] = set()
    for file_path in batch_files:
        ext = Path(file_path).suffix
        lang = _LANGUAGE_EXTENSIONS.get(ext)
        if lang:
            languages_in_batch.add(lang)

    # Collect unique module sources to read: styling per language + testing + review lens.
    sources_to_read: dict[str, str] = {}
    styling_map = manifest.get("styling", {})
    for lang in sorted(languages_in_batch):
        source = styling_map.get(lang) if isinstance(styling_map, dict) else None
        if source:
            sources_to_read[f"styling.{lang}"] = source
    for slot in ("common", "testing", REVIEW_SLOT_KEY):
        source = manifest.get(slot)
        if isinstance(source, str):
            sources_to_read[slot] = source

    if not sources_to_read:
        return ""

    sections: list[str] = []
    for slot_label, source in sources_to_read.items():
        module_path = _resolve_source_path(source, project_root)
        if module_path:
            content = module_path.read_text().strip()
            sections.append(f"── {slot_label} ({source}) ──\n{content}")

    if not sections:
        return ""

    return "\n\n".join(sections)

# ── markdown parsers ───────────────────────────────────────────────────────────

def parse_tasks(tasks_md: Path) -> list[dict]:
    if not tasks_md.exists():
        return []

    tasks: list[dict] = []
    current: dict | None = None

    for line in tasks_md.read_text().splitlines():
        header_match = TASK_HEADER_RE.match(line)
        if header_match:
            if current:
                tasks.append(current)
            current = {
                "tag": header_match.group(1),
                "action": header_match.group(2),
                "target": header_match.group(3),
                "status": TASK_STATUS_PENDING,
                "component_file": None,
                "blocked_by": [],
                "raw_lines": [line],
            }
        elif current is not None:
            current["raw_lines"].append(line)
            stripped = line.strip()
            if stripped.startswith("Status:"):
                status_value = stripped.split(":", 1)[1].strip()
                if status_value in VALID_TASK_STATUSES:
                    current["status"] = status_value
            elif stripped.startswith("Component file:"):
                current["component_file"] = stripped.split(":", 1)[1].strip()
            elif stripped.startswith("Blocked by:"):
                blocked_text = stripped.split(":", 1)[1]
                current["blocked_by"].extend(BLOCKED_BY_TAG_RE.findall(blocked_text))

    if current:
        tasks.append(current)

    return tasks


def parse_feature_acs(objective_md: Path) -> list[str]:
    if not objective_md.exists():
        return []
    text = objective_md.read_text()
    section_match = re.search(
        r"## (?:Functional ACs|Feature Change List).*?(?=^## |\Z)",
        text,
        re.MULTILINE | re.DOTALL,
    )
    if not section_match:
        return []
    return FEATURE_AC_RE.findall(section_match.group(0))


def parse_component_names(objective_md: Path) -> list[str]:
    # Component Summary lives in components/_overview.md; older bundles kept it in objective.md.
    overview_md = objective_md.parent / "components" / "_overview.md"
    for source in (overview_md, objective_md):
        if not source.exists():
            continue
        section_match = re.search(
            r"## Component Summary.*?(?=^## |\Z)",
            source.read_text(),
            re.MULTILINE | re.DOTALL,
        )
        if not section_match:
            continue
        table_names = re.findall(r"\|\s*\d+\.\d+\s*\|\s*(\w+)\s*\|", section_match.group(0))
        block_names = re.findall(r"^###\s+\d+\.\d+\s+(\w+)", section_match.group(0), re.MULTILINE)
        names = table_names + block_names
        if names:
            return names
    return []


def update_task_status_in_file(tasks_md: Path, tag: str, new_status: str) -> None:
    lines = tasks_md.read_text().splitlines(keepends=True)
    in_target_task = False
    updated = False
    result: list[str] = []

    for line in lines:
        stripped = line.rstrip()
        header_match = TASK_HEADER_RE.match(stripped)
        if header_match:
            in_target_task = header_match.group(1) == tag
        if in_target_task and re.match(r"^Status:\s*\w+", stripped) and not updated:
            result.append(f"Status: {new_status}\n")
            updated = True
        else:
            result.append(line)

    if not updated:
        _exit_error(f"Status: line not found for task '{tag}' in {tasks_md}")

    tasks_md.write_text("".join(result))

# ── helpers ────────────────────────────────────────────────────────────────────

def _exit_error(message: str) -> None:
    print(f"error: {message}", file=sys.stderr)
    sys.exit(1)


def _resolve_single_or_all(name: str | None) -> list[Path]:
    if name:
        return [resolve_schematic_dir(name)]
    dirs = list_schematic_dirs()
    if not dirs:
        _exit_error("no schematics found under docs/schematics/")
    return dirs

# ── init command ──────────────────────────────────────────────────────────────

