tests/
```
"""

_OVERVIEW_STUB = """\
# Components Overview

## Component Summary

<!-- One ### sub-heading per logical group (service + the internals that change
     with it); Service row first, then its internals. Never one flat table. -->

### <group>

| # | Class | Type | Class AC (responsibility) | Necessitated by |
|---|---|---|---|---|

## Injection DAG
> Authoritative: ../dag.mmd (when >8 nodes)

Edge inventory (by layer):

## App Integration

## Sequence Diagram
> Mermaid: ../sequence.mmd

## AC Traceability Matrix

| Feature AC | Class AC | Function AC | AC Test |
|---|---|---|---|
"""

_TASKS_STUB = "# Tasks\n"
_DAG_STUB = "flowchart TD\n"
_SEQUENCE_STUB = "sequenceDiagram\n"


def _report_standards_manifest(project_root: Path) -> None:
    """Slot-by-slot manifest coverage — the onboarding cue for Phase 0."""
    repo_manifest = project_root / STANDARDS_MANIFEST_RELPATH
    global_manifest = Path.home() / STANDARDS_MANIFEST_RELPATH

    if not repo_manifest.exists() and not global_manifest.exists():
        print("standards: NO MANIFEST FOUND")
        print("  Phase 0 onboards you (standards_resolution.md):")
        print("    1. map slots to skills you already have (architecture/types/styling/testing/review), or")
        print("    2. LEARN — derive each unmapped slot from your codebase's exemplar directories.")
        print("  These modules feed every stage: topology + contracts (plan), sketches (implement),")
        print("  diff sweeps + audits (review). Run Phase 0 before Phase 1.")
        return

    source_label = (
        f"{repo_manifest.relative_to(project_root)} (repo manifest)"
        if repo_manifest.exists()
        else f"{global_manifest} (global default — Phase 0 confirms + copies it into the repo)"
    )
    print(f"standards: {source_label}")

    manifest = _load_standards_manifest(project_root)
    slot_paths = _resolved_slot_paths(project_root)
    unmapped: list[str] = []
    for slot in STANDARDS_SLOTS:
        if slot == "exemplars":
            exemplars = manifest.get("exemplars", [])
            status = ", ".join(exemplars) if exemplars else "—"
            print(f"  exemplars:    {status}")
            continue
        if slot == "styling":
            styling_paths = {k: v for k, v in slot_paths.items() if k.startswith("styling.")}
            if styling_paths:
                for lang_slot, path in sorted(styling_paths.items()):
                    print(f"  {lang_slot + ':':<13} {path}")
            else:
                unmapped.append("styling")
                print("  styling:      UNMAPPED")
            continue
        if slot in slot_paths:
            print(f"  {slot + ':':<13} {slot_paths[slot]}")
        else:
            unmapped.append(slot)
            print(f"  {slot + ':':<13} UNMAPPED")
    if unmapped:
        print(f"  → Phase 0 resolves unmapped slots ({', '.join(unmapped)}): map an existing")
        print("    module or LEARN it from the codebase (standards_resolution.md → Learn mode).")


_ANSI_CYAN = "\033[36m"
_ANSI_BOLD = "\033[1m"
_ANSI_DIM = "\033[2m"
_ANSI_RESET = "\033[0m"
_BANNER_LINE_DELAY_SECONDS = 0.05
_BANNER_TICK_DELAY_SECONDS = 0.04


def _print_init_banner(feature_name: str) -> None:
    """Blueprint-style intro. Animated on a TTY; plain single print otherwise."""
    is_tty = sys.stdout.isatty()
    cyan, bold, dim, reset = (
        (_ANSI_CYAN, _ANSI_BOLD, _ANSI_DIM, _ANSI_RESET) if is_tty else ("", "", "", "")
    )
    banner_lines = [
        f"{cyan}███████╗ ██████╗██╗  ██╗███████╗███╗   ███╗ █████╗ ████████╗██╗ ██████╗{reset}",
        f"{cyan}██╔════╝██╔════╝██║  ██║██╔════╝████╗ ████║██╔══██╗╚══██╔══╝██║██╔════╝{reset}",
        f"{cyan}███████╗██║     ███████║█████╗  ██╔████╔██║███████║   ██║   ██║██║{reset}",
        f"{cyan}╚════██║██║     ██╔══██║██╔══╝  ██║╚██╔╝██║██╔══██║   ██║   ██║██║{reset}",
        f"{cyan}███████║╚██████╗██║  ██║███████╗██║ ╚═╝ ██║██║  ██║   ██║   ██║╚██████╗{reset}",
        f"{cyan}╚══════╝ ╚═════╝╚═╝  ╚═╝╚══════╝╚═╝     ╚═╝╚═╝  ╚═╝   ╚═╝   ╚═╝ ╚═════╝{reset}",
        "",
        f"        {dim}t h e   d e s i g n   i s   t h e   c o n t r a c t{reset}",
        "",
        f" {dim}spec ─▶ topology ─▶ contracts ─▶ DAG ─▶ sequence ─▶ tasks ─▶ build ─▶ compress{reset}",
        f" {dim}└────────────────── audit ▸ sign-off ▸ lock at every gate ───────────────────┘{reset}",
        "",
        f"  {bold}drafting:{reset} {feature_name}",
        "",
    ]
    for line in banner_lines:
        print(line, flush=True)
        if is_tty:
            time.sleep(_BANNER_LINE_DELAY_SECONDS)


def cmd_init(args: argparse.Namespace) -> None:
    root = find_project_root()
    schematic_dir = root / SCHEMATICS_BASE / args.name
    if schematic_dir.exists():
        _exit_error(f"schematic '{args.name}' already exists at {schematic_dir}")

    _print_init_banner(args.name)

    components_dir = schematic_dir / "components"
    components_dir.mkdir(parents=True)
    research_dir = schematic_dir / "research"
    research_dir.mkdir(parents=True)

    (schematic_dir / "objective.md").write_text(_OBJECTIVE_STUB.format(name=args.name))
    (schematic_dir / "tasks.md").write_text(_TASKS_STUB)
    (schematic_dir / "dag.mmd").write_text(_DAG_STUB)
    (schematic_dir / "sequence.mmd").write_text(_SEQUENCE_STUB)
    (components_dir / "_overview.md").write_text(_OVERVIEW_STUB)
    save_state(schematic_dir, {"feature": args.name, "phases": {}, "tasks": {}, "overrides": []})

    is_tty = sys.stdout.isatty()
    print(f"created: {schematic_dir.relative_to(root)}")
    for name in ["objective.md", "tasks.md", "dag.mmd", "sequence.mmd",
                 "components/_overview.md", "research/", STATE_FILENAME]:
        print(f"  ✏︎ {name}", flush=True)
        if is_tty:
            time.sleep(_BANNER_TICK_DELAY_SECONDS)
    print()
    _report_standards_manifest(project_root=root)

# ── status command ─────────────────────────────────────────────────────────────

def cmd_status(args: argparse.Namespace) -> None:
    for schematic_dir in _resolve_single_or_all(args.name):
        _print_status(schematic_dir)
        print()


def _print_status(schematic_dir: Path) -> None:
    state = load_state(schematic_dir)
    tasks = parse_tasks(schematic_dir / "tasks.md")

    locked_phases = sorted(int(k) for k, v in state["phases"].items() if v.get("status") == PHASE_STATUS_LOCKED)
    highest_locked = max(locked_phases, default=0)
    all_phases_locked = highest_locked >= FINAL_PHASE
    current_phase = min(highest_locked + 1, FINAL_PHASE)
    phase_label = "complete" if all_phases_locked else f"{current_phase}/{FINAL_PHASE}"
    locked_line = "  ".join(f"P{n} ✓" for n in locked_phases) if locked_phases else "—"

    by_status: dict[str, list[str]] = {
        TASK_STATUS_COMPLETE: [],
        TASK_STATUS_IN_PROGRESS: [],
        TASK_STATUS_PENDING: [],
    }
    complete_tags = {t["tag"] for t in tasks if t["status"] == TASK_STATUS_COMPLETE}
    blocked_summaries: list[str] = []

    for task in tasks:
        bucket = by_status.get(task["status"], by_status[TASK_STATUS_PENDING])
        bucket.append(task["tag"])
        if task["status"] == TASK_STATUS_PENDING and task["blocked_by"]:
            active_blockers = [b for b in task["blocked_by"] if b not in complete_tags]
            if active_blockers:
                blocked_summaries.append(f"{task['tag']} ← {', '.join(active_blockers)}")

    print(f"schematic: {schematic_dir.name}")
    print(f"phase:     {phase_label}")
    print(f"locked:    {locked_line}")
    if state.get("overrides"):
        print(f"overrides: {len(state['overrides'])} (run validate to review)")

    total = len(tasks)
    print(f"\ntasks: {total} total")
    for status_key in [TASK_STATUS_COMPLETE, TASK_STATUS_IN_PROGRESS, TASK_STATUS_PENDING]:
        tags = by_status[status_key]
        if tags:
            print(f"  {status_key:<12} {len(tags):>2}  [{', '.join(tags)}]")

    if blocked_summaries:
        print("\nblocked:")
        for entry in blocked_summaries:
            print(f"  {entry}")

# ── validate command ───────────────────────────────────────────────────────────

def cmd_validate(args: argparse.Namespace) -> None:
    findings: list[str] = []
    for schematic_dir in _resolve_single_or_all(args.name):
        scoped = _validate_schematic(schematic_dir)
        findings.extend(f"[{schematic_dir.name}] {f}" for f in scoped)

    if findings:
        print(f"⚠️  {len(findings)} finding(s):\n")
        for i, finding in enumerate(findings, 1):
            print(f"  {i}. {finding}")
        sys.exit(1)
    else:
        print("✓ validate: clean")


def _validate_schematic(schematic_dir: Path) -> list[str]:
    findings: list[str] = []
    tasks = parse_tasks(schematic_dir / "tasks.md")
    all_task_tags = {t["tag"] for t in tasks}
    state = load_state(schematic_dir)

    for task in tasks:
        for blocker_tag in task["blocked_by"]:
            if blocker_tag not in all_task_tags:
                findings.append(
                    f"tasks.md #{task['tag']} — Blocked by: '{blocker_tag}' not found in task list"
                )

    for task in tasks:
        if task["component_file"]:
            component_path = schematic_dir / task["component_file"].lstrip("./")
            if not component_path.exists():
                findings.append(
                    f"tasks.md #{task['tag']} — Component file '{task['component_file']}' not found"
                )

    objective_md = schematic_dir / "objective.md"
    if objective_md.exists() and not parse_feature_acs(objective_md):
        findings.append("objective.md — no Feature ACs found in Functional ACs section")

    for task in tasks:
        state_task = state.get("tasks", {}).get(task["tag"])
        if state_task is not None:
            state_status = state_task.get("status", TASK_STATUS_PENDING)
            if state_status != task["status"]:
                findings.append(
                    f"state drift: task {task['tag']} is '{task['status']}' in tasks.md "
                    f"but '{state_status}' in {STATE_FILENAME}"
                )

    for override in state.get("overrides", []):
        findings.append(
            f"override recorded — {override['context']}: \"{override['reason']}\""
        )

    for mmd_file in sorted(schematic_dir.glob("*.mmd")):
        for mmd_finding in _validate_mermaid_file(mmd_file):
            findings.append(f"{mmd_file.name}: {mmd_finding}")

    return findings

# ── mermaid command ────────────────────────────────────────────────────────────

def cmd_mermaid(args: argparse.Namespace) -> None:
    if args.file and args.name:
        _exit_error("specify either name or --file, not both")

    if args.file:
        files = [args.file]
    elif args.name:
        schematic_dir = resolve_schematic_dir(args.name)
        files = sorted(schematic_dir.glob("*.mmd"))
    else:
        files = [f for d in list_schematic_dirs() for f in sorted(d.glob("*.mmd"))]

    if not files:
        print("no .mmd files found")
        return

    all_clean = True
    for mmd_file in files:
        file_findings = _validate_mermaid_file(mmd_file)
        if file_findings:
            all_clean = False
            print(f"⚠️  {mmd_file}")
            for finding in file_findings:
                print(f"   {finding}")
        else:
            print(f"✓  {mmd_file.name}")

    if not all_clean:
        sys.exit(1)


def _validate_mermaid_file(path: Path) -> list[str]:
    mmdc_result = _try_mmdc(path)
    if mmdc_result is not None:
        return mmdc_result
    return _heuristic_mermaid_check(path)


MMDC_INVOCATIONS = (
    ["mmdc"],
    ["npx", "--yes", "@mermaid-js/mermaid-cli"],
)
MMDC_TIMEOUT_SECONDS = 60


def _try_mmdc(path: Path) -> list[str] | None:
    for base_command in MMDC_INVOCATIONS:
        try:
            result = subprocess.run(
                [*base_command, "-i", str(path), "-o", "/dev/null"],
                capture_output=True,
                text=True,
                timeout=MMDC_TIMEOUT_SECONDS,
            )
        except (OSError, subprocess.TimeoutExpired):
            continue
        if result.returncode == 0:
            return []
        if "Parse error" in result.stderr:
            return [f"mmdc: {result.stderr.strip()}"]
    return None


def _heuristic_mermaid_check(path: Path) -> list[str]:
    content_lines = [
        line for line in path.read_text().splitlines()
        if line.strip() and not line.strip().startswith("%%")
    ]
    if not content_lines:
        return ["empty file"]

    first_line = content_lines[0].strip()

    if first_line == "sequenceDiagram":
        return _check_sequence_diagram(content_lines[1:])
    if re.match(r"^(flowchart|graph)\s+[TDLRBT]{1,2}$", first_line):
        return _check_flowchart(content_lines[1:])
    if MERMAID_UNCHECKED_TYPES_RE.match(first_line):
        return []
    return [
        f"unrecognised diagram type on line 1: '{first_line}' "
        "(expected 'sequenceDiagram' or 'flowchart TD')"
    ]


def _check_sequence_diagram(body_lines: list[str]) -> list[str]:
    findings: list[str] = []
    block_stack: list[tuple[str, int]] = []

    for lineno, raw_line in enumerate(body_lines, start=2):
        line = raw_line.strip()
        if not line or line.startswith("%%"):
            continue

        if ";" in line and not line.rstrip().endswith(";"):
            findings.append(
                f"line {lineno}: ';' inside text splits the statement "
                "(mermaid treats ';' as a separator — use '—' or ',')"
            )

        first_word = line.split()[0].lower()

        if first_word in SEQUENCE_OPENERS:
            block_stack.append((first_word, lineno))
            continue

        if first_word == "end":
            if not block_stack:
                findings.append(f"line {lineno}: 'end' with no open block")
            else:
                block_stack.pop()
            continue

        if first_word in ("participant", "actor", "activate", "deactivate", "autonumber"):
            continue

        if line.startswith("Note"):
            if not any(line.startswith(p) for p in VALID_NOTE_PREFIXES):
                findings.append(
                    f"line {lineno}: invalid Note syntax '{line[:50]}' "
                    "(use: Note over X: / Note left of X: / Note right of X:)"
                )

    for opener, open_lineno in block_stack:
        findings.append(f"unclosed '{opener}' block opened at line {open_lineno} — missing 'end'")

    return findings


def _check_flowchart(body_lines: list[str]) -> list[str]:
    findings: list[str] = []
    for lineno, raw_line in enumerate(body_lines, start=2):
        line = raw_line.strip()
        if not line or line.startswith("%%"):
            continue
        first_word = line.split()[0].lower()
        if first_word in FLOWCHART_SKIP_KEYWORDS:
            continue
        if re.match(r"^\w+\s+\w+\s*[\[\(\{]", line):
            findings.append(
                f"line {lineno}: node ID appears to contain spaces — quote it or use a single-word ID: '{line[:60]}'"
            )
    return findings

# ── setup command ─────────────────────────────────────────────────────────────

_HOOK_MARKER = "schematic-validate-hook"
_HOOK_COMMAND = (
    "python3 -c \""
    "import json,os,subprocess,pathlib;"
    "p=json.loads(os.environ.get('CLAUDE_TOOL_INPUT','{}')).get('file_path','');"
    "subprocess.run([str(pathlib.Path.home()/'.claude'/'scripts'/'schematic'),'validate'])"
    " if 'docs/schematics' in p else None"
    "\""
)
_SETTINGS_RELATIVE = Path(".claude") / "settings.json"


def cmd_setup(args: argparse.Namespace) -> None:
    project_root = find_project_root()
    settings_path = project_root / _SETTINGS_RELATIVE

    if _hook_already_installed(settings_path):
        print("schematic validate hook already installed ✓")
        return

    if not args.install:
        print("dry run — would write PostToolUse hook to:")
        print(f"  {settings_path}")
        print("\nhook triggers: schematic validate on any write to docs/schematics/")
        print("\nrun with --install to apply")
        return

    _write_hook(settings_path)
    print(f"installed: PostToolUse hook → {settings_path.relative_to(project_root)}")
    print("  triggers: schematic validate on any write to docs/schematics/")


def _hook_already_installed(settings_path: Path) -> bool:
    if not settings_path.exists():
        return False
    settings = json.loads(settings_path.read_text())
    for hook_group in settings.get("hooks", {}).get("PostToolUse", []):
        for hook in hook_group.get("hooks", []):
            if _HOOK_MARKER in hook.get("command", ""):
                return True
    return False


def _write_hook(settings_path: Path) -> None:
    settings_path.parent.mkdir(parents=True, exist_ok=True)
    settings = json.loads(settings_path.read_text()) if settings_path.exists() else {}
    hook_entry = {
        "matcher": "Write|Edit",
        "hooks": [{"type": "command", "command": f"# {_HOOK_MARKER}\n{_HOOK_COMMAND}"}],
    }
    settings.setdefault("hooks", {}).setdefault("PostToolUse", []).append(hook_entry)
    settings_path.write_text(json.dumps(settings, indent=2) + "\n")

# ── phase commands ─────────────────────────────────────────────────────────────

def cmd_phase(args: argparse.Namespace) -> None:
    phase_handlers = {
        "audit": _phase_audit,
        "sign-off": _phase_signoff,
        "complete": _phase_complete,
    }
    phase_handlers[args.phase_command](args)


def _phase_audit(args: argparse.Namespace) -> None:
    if args.num not in PHASES_REQUIRING_AUDIT:
        _exit_error(
            f"phase {args.num} does not require an audit "
            f"(audit-required phases: {sorted(PHASES_REQUIRING_AUDIT)})"
        )
    schematic_dir = resolve_schematic_dir(args.schematic)
    state = load_state(schematic_dir)
    phase_entry = state["phases"].setdefault(str(args.num), {})
    is_clean = args.result.strip().lower() == PHASE_AUDIT_CLEAN
    phase_entry["audit_result"] = PHASE_AUDIT_CLEAN if is_clean else "findings"
    phase_entry["audit_findings"] = None if is_clean else args.result
    save_state(schematic_dir, state)
    label = "clean ✓" if is_clean else "findings recorded"
    print(f"phase {args.num} audit: {label}")
    print(f"next: schematic phase sign-off {args.num} --schematic {args.schematic}")


def _phase_signoff(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    state = load_state(schematic_dir)
    state["phases"].setdefault(str(args.num), {})["signed_off"] = True
    save_state(schematic_dir, state)
    print(f"phase {args.num} signed off ✓")
    print(f"next: schematic phase complete {args.num} --schematic {args.schematic}")


def _phase_complete(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    state = load_state(schematic_dir)
    phase_entry = state["phases"].setdefault(str(args.num), {})
    context = f"phase complete {args.num}"

    if args.num in PHASES_REQUIRING_AUDIT and not phase_entry.get("audit_result"):
        if args.override:
            record_override(state, context, args.override)
        else:
            _exit_error(
                f"phase {args.num} requires an audit result before locking.\n"
                f"  run: schematic phase audit {args.num} clean --schematic {args.schematic}\n"
                f"  or:  schematic phase complete {args.num} --schematic {args.schematic} "
                f"--override \"<reason>\""
            )

    if not phase_entry.get("signed_off"):
        if args.override:
            record_override(state, context, args.override)
        else:
            _exit_error(
                f"phase {args.num} requires user sign-off before locking.\n"
                f"  run: schematic phase sign-off {args.num} --schematic {args.schematic}\n"
                f"  or:  schematic phase complete {args.num} --schematic {args.schematic} "
                f"--override \"<reason>\""
            )

    for rel_path, heading in PHASE_ARTIFACT_CHECKS.get(args.num, []):
        target = schematic_dir / rel_path
        content = target.read_text() if target.exists() else ""
        check_failed = not content if not heading else heading not in content
        if check_failed:
            if args.override:
                record_override(state, context, args.override)
                break
            else:
                reason = f"'{rel_path}' must exist and be non-empty" if not heading else f"'{rel_path}' must contain '{heading}'"
                _exit_error(
                    f"phase {args.num} artifact check failed: "
                    f"{reason}.\n"
                    f"  Write the artifact to disk before locking.\n"
                    f"  or:  schematic phase complete {args.num} --schematic {args.schematic} "
                    f"--override \"<reason>\""
                )

    for mmd_name in PHASE_MERMAID_CHECKS.get(args.num, []):
        mmd_path = schematic_dir / mmd_name
        mermaid_findings = _validate_mermaid_file(mmd_path) if mmd_path.exists() else [f"{mmd_name} missing"]
        if mermaid_findings:
            if args.override:
                record_override(state, context, args.override)
                break
            findings_text = "\n".join(f"    {finding}" for finding in mermaid_findings)
            _exit_error(
                f"phase {args.num} mermaid check failed — {mmd_name} does not validate:\n"
                f"{findings_text}\n"
                f"  fix the diagram (schematic mermaid --file {mmd_path}), then re-lock.\n"
                f"  or:  schematic phase complete {args.num} --schematic {args.schematic} "
                f"--override \"<reason>\""
            )

    state["phases"].setdefault(str(args.num), {})["status"] = PHASE_STATUS_LOCKED
    save_state(schematic_dir, state)
    print(f"phase {args.num} locked ✓")
    if args.num < PLANNING_FINAL_PHASE:
        print(f"next phase: {args.num + 1}")
    elif args.num == PLANNING_FINAL_PHASE:
        print(f"planning complete — next: schematic review start --schematic {args.schematic}  (Phase 8)")
    elif args.num == 8:
        print("next phase: 9 (compression — lock BEFORE deleting the schematic dir)")
    else:
        print("schematic complete ✓ — bundle compressed into repo docs")

# ── task commands ──────────────────────────────────────────────────────────────

def cmd_task(args: argparse.Namespace) -> None:
    task_handlers = {
        "show": _task_show,
        "status": _task_status,
        "complete": _task_complete,
        "next": _task_next,
        "note": _task_note,
        "decision": _task_decision,
        "review-result": _task_review_result,
    }
    task_handlers[args.task_command](args)


def _task_show(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    tasks = parse_tasks(schematic_dir / "tasks.md")
    task = next((t for t in tasks if t["tag"] == args.tag), None)
    if not task:
        _exit_error(f"task '{args.tag}' not found in {schematic_dir / 'tasks.md'}")

    print("\n".join(task["raw_lines"]))

    if task["component_file"]:
        component_path = schematic_dir / task["component_file"].lstrip("./")
        if component_path.exists():
            print(f"\n--- {component_path.name} ---\n")
            print(component_path.read_text())
        else:
            print(f"\nwarning: component file not found: {component_path}", file=sys.stderr)


def _task_status(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    tasks_md = schematic_dir / "tasks.md"
    tasks = parse_tasks(tasks_md)
    task = next((t for t in tasks if t["tag"] == args.tag), None)
    if not task:
        _exit_error(f"task '{args.tag}' not found in tasks.md")

    current_status = task["status"]
    new_status = args.status
    legal_targets = LEGAL_TASK_TRANSITIONS.get(current_status, set())

    if new_status not in legal_targets:
        if args.override:
            state = load_state(schematic_dir)
            record_override(
                state,
                f"task status {args.tag}: {current_status} → {new_status}",
                args.override,
            )
            save_state(schematic_dir, state)
        else:
            _exit_error(
                f"illegal transition: '{current_status}' → '{new_status}' for task {args.tag}\n"
                f"  legal from '{current_status}': {sorted(legal_targets) or 'none'}\n"
                f"  use --override \"<reason>\" to bypass"
            )

    update_task_status_in_file(tasks_md, args.tag, new_status)
    state = load_state(schematic_dir)
    state["tasks"].setdefault(args.tag, {})["status"] = new_status
    save_state(schematic_dir, state)
    print(f"task {args.tag}: {current_status} → {new_status}")

    if new_status == TASK_STATUS_REVIEW:
        review_request = {
            "tag": args.tag,
            "target": task.get("target", "unknown"),
            "component_file": task.get("component_file"),
            "requested_at": datetime.now(tz=timezone.utc).isoformat(),
            "status": "pending",
        }
        state["tasks"].setdefault(args.tag, {})["review_request"] = review_request
        save_state(schematic_dir, state)
        print(f"\n⚡ REVIEW REQUESTED for {args.tag}")
        print(f"  Target: {task.get('target', 'unknown')}")
        _emit_review_request(schematic_dir, args.tag, task)


def _emit_review_request(schematic_dir: Path, tag: str, task: dict) -> None:
    """Print the review prompt for the session agent to dispatch as a subagent."""
    project_root = find_project_root()
    review_model = _resolve_review_model(project_root)
    target = task.get("target", "unknown")
    component_spec = task.get("component_file") or "the task's component spec"

    slot_paths = _resolved_slot_paths(project_root)
    if slot_paths:
        module_lines = "\n".join(f"     - {slot}: {path}" for slot, path in sorted(slot_paths.items()))
        lens_block = (
            f"PRIMARY lens — read these resolved standards modules, then verify the\n"
            f"changed lines against them (plus the project's CLAUDE.md, which\n"
            f"overrides on conflict):\n{module_lines}\n"
        )
    else:
        lens_block = (
            f"PRIMARY lens: verify the changed lines against the project's CLAUDE.md\n"
            f"conventions (naming, suffixes, file layout, model placement, class\n"
            f"size, typing, tests, cascading).\n"
        )

    review_prompt = (
        f"Review ONLY the git-diff changes written for task '{tag}' (target: {target}).\n"
        f"Scope (HARD RULES — violations produce false flags):\n"
        f"  1. Run `git diff HEAD --stat` and `git status --short`, then read the\n"
        f"     component spec at {component_spec} to identify which of those\n"
        f"     changed files implement THIS task. Review only that intersection.\n"
        f"  2. Within each file, flag ONLY lines that are added or modified in the\n"
        f"     diff. Pre-existing code — even in the same file, even moved code\n"
        f"     whose content is unchanged — is OUT of scope. Never flag it.\n"
        f"  3. Do NOT read or review files outside the diff.\n\n"
        f"{lens_block}"
        f"SECONDARY lens — task-level correctness of the changed lines against the\n"
        f"component spec's promised behaviour. Core: wrong conditionals, unhandled edge\n"
        f"cases, swallowed exceptions, async bugs, shared-state mutation, silent-success\n"
        f"paths. Full checklist: the resolved review module above.\n"
        f"Record each finding as a note (do NOT complete the task — completion\n"
        f"stays with the implementing agent):\n"
        f"  schematic task note {tag} \"<finding>\" --schematic {schematic_dir.name}\n"
        f"Final line of your reply: VERDICT: clean | VERDICT: findings\n"
    )

    print(f"  ↪ SESSION AGENT: launch this review as a {review_model} subagent (Agent tool),")
    print(f"    then record the verdict: schematic task review-result {tag} <clean|findings> --summary \"<one line>\" --schematic {schematic_dir.name}")
    print("    Task cannot complete until the recorded verdict is 'clean'.\n")
    print("  ── review prompt ───────────────────────────────────────────────")
    print(textwrap.indent(review_prompt, "  "))
    print("  ────────────────────────────────────────────────────────────────")


def _task_review_result(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    state = load_state(schematic_dir)
    task_state = state["tasks"].get(args.tag)
    if not task_state or "review_request" not in task_state:
        _exit_error(
            f"no review request recorded for task {args.tag}\n"
            f"  run: schematic task status {args.tag} review --schematic {args.schematic}"
        )

    review_request = task_state["review_request"]
    review_request["status"] = args.verdict
    review_request["summary"] = args.summary
    review_request["recorded_at"] = datetime.now(tz=timezone.utc).isoformat()
    save_state(schematic_dir, state)
    print(f"review result for {args.tag}: {args.verdict} — {args.summary}")
    if args.verdict == REVIEW_VERDICT_CLEAN:
        print(f"  next: schematic task complete {args.tag} --schematic {args.schematic}")
    else:
        print("  resolve every finding (see task notes), re-run tests, then re-dispatch:")
        print(f"  schematic task status {args.tag} review --schematic {args.schematic}")


def _task_complete(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    tasks_md = schematic_dir / "tasks.md"
    tasks = parse_tasks(tasks_md)
    task = next((t for t in tasks if t["tag"] == args.tag), None)
    if not task:
        _exit_error(f"task '{args.tag}' not found in tasks.md")

    review_state = load_state(schematic_dir)["tasks"].get(args.tag, {}).get("review_request")
    review_verdict = review_state["status"] if review_state else None
    if review_verdict != REVIEW_VERDICT_CLEAN:
        if args.override:
            state = load_state(schematic_dir)
            record_override(
                state,
                f"task complete {args.tag} without clean review (verdict: {review_verdict or 'never dispatched'})",
                args.override,
            )
            save_state(schematic_dir, state)
        else:
            _exit_error(
                f"task {args.tag} has no clean review recorded "
                f"(review verdict: {review_verdict or 'never dispatched'})\n"
                f"  run: schematic task status {args.tag} review --schematic {args.schematic}\n"
                f"  then: schematic task review-result {args.tag} clean --summary \"<one line>\" --schematic {args.schematic}\n"
                f"  or:   schematic task complete {args.tag} --schematic {args.schematic} --override \"<reason>\""
            )

    if task["status"] not in {TASK_STATUS_IN_PROGRESS, TASK_STATUS_REVIEW}:
        if args.override:
            state = load_state(schematic_dir)
            record_override(
                state,
                f"task complete {args.tag} (was '{task['status']}')",
                args.override,
            )
            save_state(schematic_dir, state)
        else:
            _exit_error(
                f"task {args.tag} must be in_progress or review to complete "
                f"(currently: '{task['status']}')\n"
                f"  run: schematic task status {args.tag} in_progress --schematic {args.schematic}\n"
                f"  or:  schematic task complete {args.tag} --schematic {args.schematic} "
                f"--override \"<reason>\""
            )

    update_task_status_in_file(tasks_md, args.tag, TASK_STATUS_COMPLETE)
    state = load_state(schematic_dir)
    state["tasks"].setdefault(args.tag, {})["status"] = TASK_STATUS_COMPLETE
    save_state(schematic_dir, state)
    print(f"task {args.tag}: complete ✓")


def _task_next(args: argparse.Namespace) -> None:
    name = getattr(args, "name", None)
    peek = getattr(args, "peek", False)
    schematic_dirs = _resolve_single_or_all(name)

    for schematic_dir in schematic_dirs:
        tasks_md = schematic_dir / "tasks.md"
        tasks = parse_tasks(tasks_md)
        complete_tags = {t["tag"] for t in tasks if t["status"] == TASK_STATUS_COMPLETE}

        for task in tasks:
            if task["status"] != TASK_STATUS_PENDING:
                continue
            active_blockers = [b for b in task["blocked_by"] if b not in complete_tags]
            if active_blockers:
                continue
            print(f"schematic: {schematic_dir.name}")
            print("\n".join(task["raw_lines"]))
            if not peek:
                update_task_status_in_file(tasks_md, task["tag"], TASK_STATUS_IN_PROGRESS)
                state = load_state(schematic_dir)
                state["tasks"].setdefault(task["tag"], {})["status"] = TASK_STATUS_IN_PROGRESS
                save_state(schematic_dir, state)
                print(f"\n→ task {task['tag']}: pending → in_progress")
            return

    print("no pending unblocked tasks found")


def _task_note(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    state = load_state(schematic_dir)
    task_state = state["tasks"].setdefault(args.tag, {})
    notes = task_state.setdefault("notes", [])
    notes.append({"text": args.text, "ts": datetime.now(tz=timezone.utc).isoformat()})
    save_state(schematic_dir, state)
    print(f"note added to {args.tag}: {args.text}")


def _task_decision(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    state = load_state(schematic_dir)
    task_state = state["tasks"].setdefault(args.tag, {})
    decisions = task_state.setdefault("decisions", [])
    decisions.append({"text": args.text, "ts": datetime.now(tz=timezone.utc).isoformat()})
    save_state(schematic_dir, state)
    print(f"decision recorded for {args.tag}: {args.text}")


def _print_decision_ledger(state: dict) -> None:
    """Print every recorded autonomous decision so the master folds them into implementation_report.md."""
    tag_to_decisions = {
        tag: task_state["decisions"]
        for tag, task_state in state["tasks"].items()
        if task_state.get("decisions")
    }
    if not tag_to_decisions:
        return
    print()
    print("AUTONOMOUS DECISIONS (fold into implementation_report.md § Autonomous decisions):")
    for tag, decisions in sorted(tag_to_decisions.items()):
        for decision in decisions:
            print(f"  {tag}: {decision['text']}")


# ── dashboard Q&A relay (questions asked in the browser UIs) ─────────────────────

QUESTIONS_SUFFIX = ".questions.json"
ANSWERS_SUFFIX = ".answers.json"
AGENT_REQUESTS_SUFFIX = ".agent-requests.json"


def _load_json_list(path: Path) -> list[dict]:
    if not path.exists():
        return []
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError:
        return []


def _pending_questions(schematic_dir: Path) -> list[dict]:
    """Unanswered UI questions across the bundle: [{id, source, idx, text, prompt}]."""
    pending: list[dict] = []
    for questions_path in sorted(schematic_dir.glob(f"*{QUESTIONS_SUFFIX}")):
        stem = questions_path.name[: -len(QUESTIONS_SUFFIX)]
        answered_idxs = {
            a.get("idx") for a in _load_json_list(schematic_dir / f"{stem}{ANSWERS_SUFFIX}")
        }
        idx_to_prompt = {
            r.get("idx"): r.get("prompt", "")
            for r in _load_json_list(schematic_dir / f"{stem}{AGENT_REQUESTS_SUFFIX}")
        }
        for position, question in enumerate(_load_json_list(questions_path)):
            idx = question.get("server_idx", question.get("idx", position))
            if idx in answered_idxs:
                continue
            user_msgs = [m.get("text", "") for m in question.get("thread", []) if m.get("role") == "user"]
            text = user_msgs[-1] if user_msgs else question.get("text", "")
            if not text:
                continue
            pending.append({
                "id": f"{stem}#{idx}",
                "source": stem,
                "idx": idx,
                "text": text,
                "context": question.get("context", ""),
                "prompt": idx_to_prompt.get(idx, ""),
            })
    return pending


def cmd_questions(args: argparse.Namespace) -> None:
    total_pending = 0
    for schematic_dir in _resolve_single_or_all(args.name):
        pending = _pending_questions(schematic_dir)
        if not pending:
            continue
        total_pending += len(pending)
        print(f"schematic: {schematic_dir.name} — {len(pending)} unanswered dashboard question(s)\n")
        for question in pending:
            print(f"── {question['id']}  ({question['context'] or 'dashboard'}) ──")
            if question["prompt"]:
                print(question["prompt"])
            else:
                print(f"  User: {question['text']}")
            print()
        print(f"answer with: schematic answer <id> \"<text>\" {schematic_dir.name}")
        print("  (the dashboard bubble picks the answer up live)")
    if total_pending == 0:
        print("no unanswered dashboard questions")


def cmd_answer(args: argparse.Namespace) -> None:
    if "#" not in args.id:
        _exit_error(f"invalid question id '{args.id}' — expected <source>#<idx> (e.g. overview#0, sequence#2)")
    stem, _, idx_text = args.id.partition("#")
    if not idx_text.isdigit():
        _exit_error(f"invalid question id '{args.id}' — idx must be a number")
    idx = int(idx_text)

    schematic_dirs = _resolve_single_or_all(args.name)
    for schematic_dir in schematic_dirs:
        questions_path = schematic_dir / f"{stem}{QUESTIONS_SUFFIX}"
        if not questions_path.exists():
            continue
        answers_path = schematic_dir / f"{stem}{ANSWERS_SUFFIX}"
        answers = _load_json_list(answers_path)
        answers.append({"idx": idx, "answer": args.text})
        answers_path.write_text(json.dumps(answers, indent=2) + "\n")
        print(f"answer delivered to {args.id} ({schematic_dir.name}) — the dashboard picks it up within ~2s")
        return
    _exit_error(f"no question source '{stem}' found ({stem}{QUESTIONS_SUFFIX} missing in the schematic dir)")


# ── review (auto-mode driver + batch-until-pristine sweep) ───────────────────────

def cmd_review(args: argparse.Namespace) -> None:
    handlers = {
        "start": _review_start,
        "sweep": _review_sweep,
        "batch-result": _review_batch_result,
        "e2e": _review_e2e,
        "e2e-result": _review_e2e_result,
        "status": _review_status,
    }
    handlers[args.review_command](args)


def _review_start(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    project_root = find_project_root()
    mode = RUN_MODE_AUTO if args.auto else RUN_MODE_MANUAL
    if mode == RUN_MODE_AUTO and not args.goal:
        _exit_error("auto mode requires a goal: schematic review start --auto --goal \"<goal>\" --schematic <name>")
    base_ref = _run_git(["rev-parse", "HEAD"], project_root)[0]
    state = load_state(schematic_dir)
    state["run"] = {
        "mode": mode,
        "goal": args.goal,
        "base_ref": base_ref,
        "started_at": datetime.now(tz=timezone.utc).isoformat(),
    }
    save_state(schematic_dir, state)
    print(f"run started: mode={mode} base_ref={base_ref[:12]}")
    if mode == RUN_MODE_AUTO:
        print(f"  goal: {args.goal}")
        print("  MANDATE: record every decision the schematic doesn't answer, AT THE MOMENT IT'S MADE:")
        print(f"    schematic task decision <tag> \"<what> — <why>\" --schematic {args.schematic}")
        print("  drive the board; per-task reviews run diff-scoped as you go, then:")
        print(f"  schematic review sweep --schematic {args.schematic}")


def _review_sweep(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    project_root = find_project_root()
    review_model = _resolve_review_model(project_root)
    state = load_state(schematic_dir)
    run = state["run"]
    if not run or run["mode"] != RUN_MODE_AUTO:
        _exit_error(
            "no auto run recorded — start one first:\n"
            f"  schematic review start --auto --goal \"<goal>\" --schematic {args.schematic}"
        )
    diff_files = _cumulative_diff_files(run["base_ref"], project_root)
    if not diff_files:
        _exit_error(f"no changes since base_ref {run['base_ref'][:12]} — nothing to sweep")

    # Token efficiency: a file whose diff is byte-identical to one already reviewed
    # clean in a prior sweep needs no re-review — only re-touched files re-enter.
    file_to_diff = {
        path: _file_diff(path, run["base_ref"], project_root)
        for path in diff_files
    }
    clean_file_hashes = _clean_reviewed_file_hashes(state)
    files_to_review = [
        path for path in diff_files
        if _diff_hash(file_to_diff[path]) not in clean_file_hashes.get(path, set())
    ]
    skipped_clean = sorted(set(diff_files) - set(files_to_review))

    sweep_id = len(state["sweeps"]) + 1
    if not files_to_review:
        state["sweeps"].append({
            "sweep_id": sweep_id, "batches": [], "pristine": True,
            "skipped_clean": skipped_clean,
        })
        save_state(schematic_dir, state)
        print(f"sweep {sweep_id}: PRISTINE ✓ — all {len(skipped_clean)} changed file(s) "
              f"unchanged since their last clean review")
        print(f"  next: schematic review e2e --schematic {args.schematic}")
        return

    batches = _shard_diff_into_batches(files_to_review, MAX_FILES_PER_REVIEW_BATCH)
    sweep_record = {
        "sweep_id": sweep_id,
        "batches": [
            {
                "batch_id": f"{sweep_id}.{index + 1}",
                "files": batch,
                "file_hashes": {path: _diff_hash(file_to_diff[path]) for path in batch},
                "verdict": "pending",
                "summary": None,
            }
            for index, batch in enumerate(batches)
        ],
        "pristine": False,
        "skipped_clean": skipped_clean,
    }
    state["sweeps"].append(sweep_record)
    save_state(schematic_dir, state)

    batch_diffs = {
        batch["batch_id"]: "".join(file_to_diff[path] for path in batch["files"])
        for batch in sweep_record["batches"]
    }
    if skipped_clean:
        print(f"skipped {len(skipped_clean)} file(s) unchanged since last clean review: "
              f"{', '.join(skipped_clean)}")
    _emit_sweep_prompts(schematic_dir, sweep_record, batch_diffs, review_model)


def _emit_sweep_prompts(
    schematic_dir: Path,
    sweep_record: dict,
    batch_diffs: dict[str, str],
    review_model: str,
) -> None:
    batches = sweep_record["batches"]
    project_root = find_project_root()
    print(f"sweep {sweep_record['sweep_id']}: {len(batches)} batch(es) — diff-only style review "
          f"(≤{MAX_FILES_PER_REVIEW_BATCH} files each)")
    for batch in batches:
        diff_content = batch_diffs.get(batch["batch_id"], "")
        standards_content = _resolve_standards_content_for_batch(batch["files"], project_root)
        _emit_batch_review_prompt(schematic_dir, batch, diff_content, standards_content)
    print(f"\n  dispatch each batch as a {review_model} subagent, fix every finding, then record:")
    print(f"    schematic review batch-result <batch_id> clean|findings --summary \"<one line>\" "
          f"--schematic {schematic_dir.name}")
    print("  re-run `review sweep` after fixes; PRISTINE = a sweep where every batch is clean.")
    print("  after PRISTINE: run `schematic review e2e --schematic <name>` for master-agent correctness gate.")


def _emit_batch_review_prompt(
    schematic_dir: Path,
    batch: dict,
    diff_content: str,
    standards_content: str,
) -> None:
    file_list = "\n".join(f"    - {path}" for path in batch["files"])
    review_prompt = (
        f"Review batch {batch['batch_id']} — STYLE + STANDARDS review of these changes:\n"
        f"Files in this batch:\n"
        f"{file_list}\n\n"
        f"Scope (HARD RULES — violations are false flags + wasted tokens):\n"
        f"  1. Do NOT read, open, or grep ANY files. The diff below is your ONLY input.\n"
        f"  2. Flag ONLY lines that appear as added (+) or modified in the diff.\n"
        f"     Pre-existing/unchanged context lines are OUT of scope — never flag them.\n"
        f"  3. Never flag or edit code outside the feature.\n\n"
        f"── DIFF ──\n"
        f"{diff_content}\n"
        f"── END DIFF ──\n\n"
    )

    if standards_content:
        review_prompt += (
            f"── STANDARDS (judge the diff against these) ──\n"
            f"{standards_content}\n"
            f"── END STANDARDS ──\n\n"
        )

    review_prompt += (
        f"Output: a numbered list of findings (file:line — issue — required fix), then a final\n"
        f"line: VERDICT: clean (zero findings) | VERDICT: findings\n"
    )
    print(f"\n  ── batch {batch['batch_id']} review prompt ──────────────────────")
    print(textwrap.indent(review_prompt, "  "))


def _review_batch_result(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    state = load_state(schematic_dir)
    target_sweep = None
    target_batch = None
    for sweep in state["sweeps"]:
        for batch in sweep["batches"]:
            if batch["batch_id"] == args.batch_id:
                target_sweep = sweep
                target_batch = batch
    if target_batch is None:
        _exit_error(f"batch '{args.batch_id}' not found — run `schematic review sweep --schematic {args.schematic}` first")
    target_batch["verdict"] = args.verdict
    target_batch["summary"] = args.summary
    all_clean = all(b["verdict"] == REVIEW_VERDICT_CLEAN for b in target_sweep["batches"])
    target_sweep["pristine"] = all_clean
    save_state(schematic_dir, state)
    print(f"batch {args.batch_id}: {args.verdict} — {args.summary}")
    if all_clean:
        print(f"  sweep {target_sweep['sweep_id']}: PRISTINE ✓ — all {len(target_sweep['batches'])} batches clean")
    else:
        outstanding = [b["batch_id"] for b in target_sweep["batches"] if b["verdict"] != REVIEW_VERDICT_CLEAN]
        print(f"  sweep {target_sweep['sweep_id']}: not pristine — outstanding: {', '.join(outstanding)}")
        print(f"  fix findings, then re-run: schematic review sweep --schematic {args.schematic}")


def _review_e2e(args: argparse.Namespace) -> None:
    """Master-agent correctness gate — runs after the diff-only sweep reaches PRISTINE."""
    schematic_dir = resolve_schematic_dir(args.schematic)
    project_root = find_project_root()
    state = load_state(schematic_dir)
    run = state["run"]
    if not run or run["mode"] != RUN_MODE_AUTO:
        _exit_error(
            "no auto run recorded — start one first:\n"
            f"  schematic review start --auto --goal \"<goal>\" --schematic {args.schematic}"
        )

    # Verify a pristine sweep exists.
    has_pristine = any(sweep.get("pristine") for sweep in state["sweeps"])
    if not has_pristine:
        _exit_error(
            "no PRISTINE sweep recorded — run the diff-only style sweep first:\n"
            f"  schematic review sweep --schematic {args.schematic}"
        )

    diff_files = _cumulative_diff_files(run["base_ref"], project_root)
    if not diff_files:
        _exit_error(f"no changes since base_ref {run['base_ref'][:12]} — nothing to review")

    # Record e2e gate start.
    state.setdefault("e2e", None)
    state["e2e"] = {
        "status": "pending",
        "started_at": datetime.now(tz=timezone.utc).isoformat(),
        "verdict": None,
        "summary": None,
    }
    save_state(schematic_dir, state)

    file_list = "\n".join(f"  - {path}" for path in diff_files)
    print(f"e2e correctness gate — {len(diff_files)} changed files for master-agent review:")
    print(file_list)
    print()
    print("MASTER AGENT: review all changed files for correctness, integration, and contract fidelity.")
    print("This is NOT a style review (the sweep handled that). Check:")
    print("  1. Read every changed file (full content, not just diff).")
    print("  2. Verify wiring: DI constructor args match, imports resolve, method signatures match callers.")
    print("  3. Verify contracts: implementation matches the locked schematic component specs.")
    print("  4. Verify test coverage: every schematic AC test exists and tests the right behaviour.")
    print("  5. Verify integration: cross-component call flows are correct (sequence diagram vs code).")
    print("  6. Verify correctness: wrong conditionals, edge cases, swallowed exceptions, async bugs,")
    print("     shared-state mutation, silent-success paths — full checklist in the resolved review module.")
    print("  7. Verify blast radius: for each changed public signature/behaviour, grep dependents +")
    print("     derived-key sites (cache/memo/dedupe/etag/hash/__eq__) — every result-determining input")
    print("     must appear in every derived key. Full checklist in the resolved review module.")
    _print_decision_ledger(state)
    print()
    if run["mode"] == RUN_MODE_AUTO:
        print("AUTO MODE: fix any findings silently, then record the result. No user gate required —")
        print("the implementation report will note the e2e verdict.")
    else:
        print("Present findings to the user with `Confirm: y/comment`.")
    print(f"  schematic review e2e-result clean|findings --summary \"<one line>\" --schematic {args.schematic}")


def _review_e2e_result(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    state = load_state(schematic_dir)
    e2e = state.get("e2e")
    if not e2e:
        _exit_error(
            f"no e2e gate recorded — run `schematic review e2e --schematic {args.schematic}` first"
        )
    e2e["status"] = args.verdict
    e2e["verdict"] = args.verdict
    e2e["summary"] = args.summary
    e2e["completed_at"] = datetime.now(tz=timezone.utc).isoformat()
    save_state(schematic_dir, state)
    print(f"e2e result: {args.verdict} — {args.summary}")
    if args.verdict == REVIEW_VERDICT_CLEAN:
        print("  feature review complete — style sweep PRISTINE + e2e CLEAN.")
    else:
        print("  resolve findings, then re-run:")
        print(f"    schematic review e2e --schematic {args.schematic}")


def _review_status(args: argparse.Namespace) -> None:
    schematic_dir = resolve_schematic_dir(args.schematic)
    state = load_state(schematic_dir)
    run = state["run"]
    if not run:
        print(f"no run recorded — schematic review start --schematic {args.schematic}")
        return
    print(f"mode: {run['mode']}  base_ref: {run['base_ref'][:12]}")
    if run["goal"]:
        print(f"goal: {run['goal']}")
    if not state["sweeps"]:
        print("sweeps: none yet")
        return
    latest_sweep = state["sweeps"][-1]
    pristine_flag = "PRISTINE ✓" if latest_sweep["pristine"] else "not pristine"
    print(f"latest sweep {latest_sweep['sweep_id']}: {pristine_flag} ({len(latest_sweep['batches'])} batches)")
    for batch in latest_sweep["batches"]:
        print(f"  {batch['batch_id']:<6} {batch['verdict']:<9} [{', '.join(batch['files'])}]")
    e2e = state.get("e2e")
    if e2e:
        e2e_flag = "CLEAN ✓" if e2e.get("verdict") == REVIEW_VERDICT_CLEAN else e2e.get("status", "pending")
        print(f"e2e correctness: {e2e_flag}")
        if e2e.get("summary"):
            print(f"  {e2e['summary']}")


# ── track (lazy-loaded) ───────────────────────────────────────────────────────

def cmd_track(args: argparse.Namespace) -> None:
    import importlib.util
    script_dir = Path(__file__).resolve().parent
    spec = importlib.util.spec_from_file_location("track", script_dir / "track.py")
    if spec is None or spec.loader is None:
        _exit_error("track.py not found — skill may be corrupted")
    track_mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(track_mod)

    schematic_dir = resolve_schematic_dir(args.schematic)
    if args.track_command == "init":
        track_mod.cmd_track_init(
            schematic_dir=schematic_dir,
            entry=args.entry,
            trace_name=args.trace,
        )
    elif args.track_command == "validate":
        track_mod.cmd_track_validate(
            schematic_dir=schematic_dir,
            trace_name=getattr(args, "trace", None),
        )
    elif args.track_command == "show":
        track_mod.cmd_track_show(
            schematic_dir=schematic_dir,
            trace_name=getattr(args, "trace", None),
        )


# ── overview (lazy-loaded) ────────────────────────────────────────────────────

def cmd_overview(args: argparse.Namespace) -> None:
    import importlib.util
    script_dir = Path(__file__).resolve().parent
    spec = importlib.util.spec_from_file_location("overview", script_dir / "overview.py")
    if spec is None or spec.loader is None:
        _exit_error("overview.py not found — skill may be corrupted")
    overview_mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(overview_mod)

    if args.name:
        schematic_dir = resolve_schematic_dir(args.name)
    else:
        dirs = list_schematic_dirs()
        if not dirs:
            _exit_error("no schematics found")
        schematic_dir = dirs[-1]

    overview_mod.launch_overview(schematic_dir)

# ── argparse + dispatch ───────────────────────────────────────────────────────

def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="schematic", description="Schematic planning workflow CLI")
    sub = parser.add_subparsers(dest="command", required=True)

    p_init = sub.add_parser("init", help="Scaffold a new schematic directory")
    p_init.add_argument("name", help="Feature name (kebab-case)")

    p_status = sub.add_parser("status", help="Show task progress")
    p_status.add_argument("name", nargs="?", help="Schematic name (omit for all)")

    p_validate = sub.add_parser("validate", help="AC pyramid + cross-ref integrity check")
    p_validate.add_argument("name", nargs="?", help="Schematic name (omit for all)")

    p_mermaid = sub.add_parser("mermaid", help="Validate .mmd diagram files")
    p_mermaid.add_argument("name", nargs="?", help="Schematic name")
    p_mermaid.add_argument("--file", type=Path, help="Specific .mmd file path")

    p_phase = sub.add_parser("phase", help="Phase lifecycle commands")
    phase_sub = p_phase.add_subparsers(dest="phase_command", required=True)

    p_pa = phase_sub.add_parser("audit", help="Record audit result for a phase")
    p_pa.add_argument("num", type=int, choices=sorted(PHASES_REQUIRING_AUDIT))
    p_pa.add_argument("result", help="'clean' or findings description")
    p_pa.add_argument("--schematic", required=True, metavar="NAME")

    p_ps = phase_sub.add_parser("sign-off", help="Record user sign-off for a phase")
    p_ps.add_argument("num", type=int, choices=sorted(VALID_PHASES))
    p_ps.add_argument("--schematic", required=True, metavar="NAME")

    p_pc = phase_sub.add_parser("complete", help="Lock a phase (enforces audit + sign-off)")
    p_pc.add_argument("num", type=int, choices=sorted(VALID_PHASES))
    p_pc.add_argument("--schematic", required=True, metavar="NAME")
    p_pc.add_argument("--override", metavar="REASON", help="Bypass enforcement with reason")

    p_task = sub.add_parser("task", help="Task lifecycle commands")
    task_sub = p_task.add_subparsers(dest="task_command", required=True)

    p_tshow = task_sub.add_parser("show", help="Flatten task + component context for agent handoff")
    p_tshow.add_argument("tag", help="Task tag e.g. b.1")
    p_tshow.add_argument("--schematic", required=True, metavar="NAME")

    p_tstat = task_sub.add_parser("status", help="Update task status")
    p_tstat.add_argument("tag")
    p_tstat.add_argument("status", choices=sorted(VALID_TASK_STATUSES))
    p_tstat.add_argument("--schematic", required=True, metavar="NAME")
    p_tstat.add_argument("--override", metavar="REASON", help="Bypass legal transition check")

    p_tcomp = task_sub.add_parser("complete", help="Mark task complete (requires clean review)")
    p_tcomp.add_argument("tag")
    p_tcomp.add_argument("--schematic", required=True, metavar="NAME")
    p_tcomp.add_argument("--override", metavar="REASON", help="Bypass status + clean-review checks")

    p_trev = task_sub.add_parser("review-result", help="Record the review verdict for a task")
    p_trev.add_argument("tag", help="Task tag (e.g. b.1)")
    p_trev.add_argument("verdict", choices=sorted(REVIEW_VERDICTS))
    p_trev.add_argument("--summary", required=True, help="One-line review outcome")
    p_trev.add_argument("--schematic", required=True, metavar="NAME")

    p_tnext = task_sub.add_parser("next", help="Show next unblocked pending task and claim it")
    p_tnext.add_argument("name", nargs="?", help="Schematic name (omit for all)")
    p_tnext.add_argument("--peek", action="store_true", help="Show without claiming (no status transition)")

    p_tnote = task_sub.add_parser("note", help="Add agent note to a task")
    p_tnote.add_argument("tag", help="Task tag (e.g. a.1)")
    p_tnote.add_argument("text", help="Note text")
    p_tnote.add_argument("--schematic", required=True, metavar="NAME")

    p_tdecision = task_sub.add_parser("decision", help="Record an independent decision the schematic didn't answer (both modes — mandatory at the moment it's made; signed off at end-of-impl)")
    p_tdecision.add_argument("tag", help="Task tag (e.g. a.1)")
    p_tdecision.add_argument("text", help='Decision text: "<what was decided> — <why it was needed>"')
    p_tdecision.add_argument("--schematic", required=True, metavar="NAME")

    p_review = sub.add_parser("review", help="Auto-mode driver + batch-until-pristine diff sweep")
    review_sub = p_review.add_subparsers(dest="review_command", required=True)

    p_rstart = review_sub.add_parser("start", help="Record run mode + base ref (HEAD)")
    p_rstart.add_argument("--schematic", required=True, metavar="NAME")
    p_rstart.add_argument("--auto", action="store_true", help="Auto mode (omit for manual)")
    p_rstart.add_argument("--goal", help="Long-running goal (required in auto mode)")

    p_rsweep = review_sub.add_parser("sweep", help="Shard the cumulative diff into <=5-file review batches")
    p_rsweep.add_argument("--schematic", required=True, metavar="NAME")

    p_rresult = review_sub.add_parser("batch-result", help="Record a batch verdict; flags PRISTINE when all clean")
    p_rresult.add_argument("batch_id", help="Batch id (e.g. 1.2)")
    p_rresult.add_argument("verdict", choices=sorted(REVIEW_VERDICTS))
    p_rresult.add_argument("--summary", required=True, help="One-line batch outcome")
    p_rresult.add_argument("--schematic", required=True, metavar="NAME")

    p_re2e = review_sub.add_parser("e2e", help="Master-agent correctness gate (after PRISTINE sweep)")
    p_re2e.add_argument("--schematic", required=True, metavar="NAME")

    p_re2e_result = review_sub.add_parser("e2e-result", help="Record e2e correctness verdict")
    p_re2e_result.add_argument("verdict", choices=sorted(REVIEW_VERDICTS))
    p_re2e_result.add_argument("--summary", required=True, help="One-line e2e outcome")
    p_re2e_result.add_argument("--schematic", required=True, metavar="NAME")

    p_rstatus = review_sub.add_parser("status", help="Show run mode + latest sweep batch verdicts")
    p_rstatus.add_argument("--schematic", required=True, metavar="NAME")

    p_track = sub.add_parser("track", help="Trace a feature flow E2E")
    track_sub = p_track.add_subparsers(dest="track_command", required=True)

    p_track_init = track_sub.add_parser("init", help="Scaffold trace directory for a flow")
    p_track_init.add_argument("--schematic", required=True, metavar="NAME")
    p_track_init.add_argument("--entry", required=True, help="Entry point (file:line, class, or route)")
    p_track_init.add_argument("--trace", required=True, metavar="TRACE_NAME", help="Trace name (kebab-case)")

    p_track_validate = track_sub.add_parser("validate", help="Validate trace output files")
    p_track_validate.add_argument("--schematic", required=True, metavar="NAME")
    p_track_validate.add_argument("--trace", metavar="TRACE_NAME", help="Validate a single trace (omit for all)")

    p_track_show = track_sub.add_parser("show", help="Display trace summary")
    p_track_show.add_argument("--schematic", required=True, metavar="NAME")
    p_track_show.add_argument("--trace", metavar="TRACE_NAME", help="Show a single trace (omit for summary)")

    p_overview = sub.add_parser("overview", help="Launch schematic overview browser")
    p_overview.add_argument("name", nargs="?", help="Schematic name (omit for current)")

    p_questions = sub.add_parser("questions", help="List unanswered dashboard/editor questions")
    p_questions.add_argument("name", nargs="?", help="Schematic name (omit for all)")

    p_answer = sub.add_parser("answer", help="Answer a dashboard/editor question (UI picks it up live)")
    p_answer.add_argument("id", help="Question id from `schematic questions` (e.g. overview#0, sequence#2)")
    p_answer.add_argument("text", help="Answer text shown in the dashboard bubble")
    p_answer.add_argument("name", nargs="?", help="Schematic name (omit to search all)")

    p_setup = sub.add_parser("setup", help="Wire PostToolUse validation hook into .claude/settings.json")
    p_setup.add_argument("--install", action="store_true", help="Write hook (omit for dry run)")

    return parser


def dispatch(args: argparse.Namespace) -> None:
    handlers = {
        "init": cmd_init,
        "setup": cmd_setup,
        "status": cmd_status,
        "validate": cmd_validate,
        "mermaid": cmd_mermaid,
        "phase": cmd_phase,
        "task": cmd_task,
        "review": cmd_review,
        "track": cmd_track,
        "overview": cmd_overview,
        "questions": cmd_questions,
        "answer": cmd_answer,
    }
    handlers[args.command](args)  # type: ignore[operator]


def main() -> None:
    dispatch(_build_parser().parse_args())


if __name__ == "__main__":
    main()
